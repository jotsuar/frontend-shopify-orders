# ══════════════════════════════════════════════════════════════
#  Shopify Orders — Frontend (Vue 3)
#  Copia este archivo a .env y completa los valores reales.
#  cp .env.example .env
#
#  IMPORTANTE: Las variables VITE_* son las únicas que Vite expone
#  al código del navegador. No pongas secretos aquí.
# ══════════════════════════════════════════════════════════════

# ─── URL base de la API del backend (NestJS) ──────────────────
# Apunta al servidor NestJS. En desarrollo local: http://localhost:3000
# En producción reemplaza con la URL pública de tu backend.
VITE_API_URL=http://localhost:3000
